<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\..\FrameXML\UI.xsd">
    <Script file="DarkChaosBreakingNews.lua"/>

    <Frame name="DCBreakingNewsTicker" hidden="false" toplevel="false">
        <Size>
            <AbsDimension x="1" y="1"/>
        </Size>
        <Anchors>
            <Anchor point="TOPLEFT">
                <Offset>
                    <AbsDimension x="-2000" y="2000"/>
                </Offset>
            </Anchor>
        </Anchors>
        <Scripts>
            <OnLoad>
                self.elapsed = 0;
            </OnLoad>
            <OnUpdate>
                DCBreakingNews_OnUpdate(self, elapsed);
            </OnUpdate>
        </Scripts>
    </Frame>
</Ui>